<UserControl x:Class="ToDo.Views.Controls.TodoListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding FilteredTodos}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource BrushSurface}"
                            Height="35"
                            CornerRadius="4"
                            Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="10,0">

                            <!-- Circular checkbox -->
                            <Button Width="16" Height="16"
                                    Margin="0,0,18,0"
                                    Command="{Binding DataContext.ToggleTodoCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Ellipse Width="16" Height="16" StrokeThickness="2">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Stroke"
                                                            Value="{StaticResource BrushCbBorder}" />
                                                    <Setter Property="Fill" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}"
                                                                     Value="True">
                                                            <Setter Property="Stroke"
                                                                    Value="{StaticResource BrushAccent}" />
                                                            <Setter Property="Fill"
                                                                    Value="{StaticResource BrushAccent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Task text -->
                            <TextBlock VerticalAlignment="Center" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Task}" />
                                        <Setter Property="Foreground"
                                                Value="{StaticResource BrushText}" />
                                        <Setter Property="TextDecorations" Value="{x:Null}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource BrushMuted}" />
                                                <Setter Property="TextDecorations"
                                                        Value="Strikethrough" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>