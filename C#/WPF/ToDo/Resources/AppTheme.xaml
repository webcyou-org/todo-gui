<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Design Tokens: Colors -->
    <SolidColorBrush x:Key="BrushBG"       Color="#1C1C1C" />
    <SolidColorBrush x:Key="BrushSurface"  Color="#2A2A2A" />
    <SolidColorBrush x:Key="BrushInput"    Color="#303030" />
    <SolidColorBrush x:Key="BrushText"     Color="#D2D2D2" />
    <SolidColorBrush x:Key="BrushWhite"    Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrushMuted"    Color="#9B9B9B" />
    <SolidColorBrush x:Key="BrushAccent"   Color="#5DC2AF" />
    <SolidColorBrush x:Key="BrushCbBorder" Color="#D9D9D9" />

    <!-- Tab button base style -->
    <Style x:Key="TabButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="Foreground"       Value="{StaticResource BrushText}" />
        <Setter Property="FontSize"         Value="14" />
        <Setter Property="FontWeight"       Value="Normal" />
        <Setter Property="Height"           Value="28" />
        <Setter Property="Padding"          Value="8,0" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Cursor"           Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>