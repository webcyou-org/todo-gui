<Page x:Class="ToDo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ToDo"
      xmlns:converters="using:ToDo.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="#1C1C1C">

    <Page.Resources>
        <!--
            TextBox dark-theme overrides.
            UWP's default TextBox template references these named theme brushes,
            so overriding them here scopes the change to this page only.
        -->
        <SolidColorBrush x:Key="TextControlBackground"                    Color="#303030"/>
        <SolidColorBrush x:Key="TextControlBackgroundPointerOver"          Color="#303030"/>
        <SolidColorBrush x:Key="TextControlBackgroundFocused"              Color="#303030"/>
        <SolidColorBrush x:Key="TextControlBackgroundDisabled"             Color="#303030"/>
        <SolidColorBrush x:Key="TextControlForeground"                     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextControlForegroundPointerOver"          Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextControlForegroundFocused"              Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextControlPlaceholderForeground"          Color="#9B9B9B"/>
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#9B9B9B"/>
        <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"   Color="#9B9B9B"/>
        <SolidColorBrush x:Key="TextControlBorderBrush"                    Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"         Color="Transparent"/>
        <SolidColorBrush x:Key="TextControlBorderBrushFocused"             Color="#5DC2AF"/>
        <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>

        <!-- Value converters -->
        <converters:BoolToFontWeightConverter     x:Key="BoolToFontWeight"/>
        <converters:BoolToTextDecorationsConverter x:Key="BoolToTextDecorations"/>
        <converters:BoolToForegroundConverter      x:Key="BoolToForeground"/>
        <converters:BoolToCheckboxFillConverter    x:Key="BoolToCheckboxFill"/>
        <converters:BoolToCheckboxStrokeConverter  x:Key="BoolToCheckboxStroke"/>
        <converters:BoolToVisibilityConverter      x:Key="BoolToVisibility"/>

        <!--
            Tab button: flat appearance, no hover highlight.
            FontWeight is set on the TextBlock child so the binding can update it reactively.
        -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="Height"           Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox button: completely transparent, no hit-test chrome -->
        <Style x:Key="CheckboxButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Width"           Value="16"/>
            <Setter Property="Height"          Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!--
        Root Grid: fills the window.
        Rows: Auto (title) | Auto (input) | Auto (tabs) | * (scrollable list)
        Horizontal padding 24px, vertical padding 10px achieved via child Margin.
    -->
    <Grid Background="#1C1C1C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title: C_WHITE / 18px / Bold -->
        <TextBlock Grid.Row="0"
                   Text="ToDo"
                   Foreground="#FFFFFF"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="24,10,24,14"/>

        <!-- Input field: 35px tall, C_INPUT bg, accent focus border, placeholder C_MUTED -->
        <TextBox Grid.Row="1"
                 x:Name="TaskInput"
                 PlaceholderText="Add Task"
                 Height="35"
                 Padding="16,4"
                 CornerRadius="4"
                 FontSize="14"
                 Margin="24,0,24,14"
                 KeyDown="TaskInput_KeyDown"/>

        <!-- Tab menu: All / Active / Completed -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="24,0,24,3">
            <Button Style="{StaticResource TabButtonStyle}"
                    Click="AllTab_Click">
                <TextBlock Text="All"
                           FontWeight="{Binding IsAllActive, Converter={StaticResource BoolToFontWeight}}"
                           Foreground="#D2D2D2"
                           FontSize="14"/>
            </Button>
            <Button Style="{StaticResource TabButtonStyle}"
                    Click="ActiveTab_Click">
                <TextBlock Text="Active"
                           FontWeight="{Binding IsActiveActive, Converter={StaticResource BoolToFontWeight}}"
                           Foreground="#D2D2D2"
                           FontSize="14"/>
            </Button>
            <Button Style="{StaticResource TabButtonStyle}"
                    Click="CompletedTab_Click">
                <TextBlock Text="Completed"
                           FontWeight="{Binding IsCompletedActive, Converter={StaticResource BoolToFontWeight}}"
                           Foreground="#D2D2D2"
                           FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Scrollable todo list -->
        <ScrollViewer Grid.Row="3"
                      Margin="24,0,24,10"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredTodos}">
                <!--
                    Ensure each item ContentPresenter stretches to full width,
                    so the Border fills the available space.
                -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Todo item row: C_SURFACE bg / 35px / border-radius 4px -->
                        <Border Background="#2A2A2A"
                                Height="35"
                                CornerRadius="4"
                                Padding="10,0"
                                Margin="0,0,0,5"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- Circular checkbox: 16px, C_ACCENT when completed -->
                                <Button Style="{StaticResource CheckboxButtonStyle}"
                                        Margin="0,0,18,0"
                                        Click="Checkbox_Click">
                                    <Grid Width="16" Height="16">
                                        <Ellipse Width="16" Height="16"
                                                 Fill="Transparent"
                                                 Stroke="#D9D9D9"
                                                 StrokeThickness="2"/>
                                        <TextBlock Text="✓"
                                                   Foreground="#5DC2AF"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsCompleted,
                                                               Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>
                                </Button>

                                <!-- Task label: strikethrough + C_MUTED when completed -->
                                <TextBlock Text="{Binding Task}"
                                           Foreground="{Binding IsCompleted,
                                                       Converter={StaticResource BoolToForeground}}"
                                           TextDecorations="{Binding IsCompleted,
                                                            Converter={StaticResource BoolToTextDecorations}}"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>