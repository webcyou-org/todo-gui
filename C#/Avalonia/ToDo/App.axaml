<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:ToDo.Converters"
             x:Class="ToDo.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <SolidColorBrush x:Key="C_TEXT" Color="#D2D2D2"/>
        <SolidColorBrush x:Key="C_MUTED" Color="#9B9B9B"/>
        <SolidColorBrush x:Key="C_ACCENT" Color="#5DC2AF"/>
        <SolidColorBrush x:Key="C_CB_BORDER" Color="#D9D9D9"/>
        <converters:BoolToBrushConverter x:Key="TextColorConverter"
                                         TrueBrush="{StaticResource C_MUTED}"
                                         FalseBrush="{StaticResource C_TEXT}"/>
        <converters:BoolToTextDecorationsConverter x:Key="StrikethroughConverter"/>
        <converters:TabFontWeightConverter x:Key="TabFontWeightConverter"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#5DC2AF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="16,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="BorderBrush" Value="#5DC2AF"/>
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#9B9B9B"/>
        </Style>

        <!-- Tab button -->
        <Style Selector="Button.tab-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D2D2D2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.tab-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Circular CheckBox -->
        <Style Selector="CheckBox.circular">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="16" Height="16">
                        <Ellipse Name="PART_Ellipse"
                                 Width="16" Height="16"
                                 StrokeThickness="2"
                                 Stroke="#D9D9D9"
                                 Fill="Transparent"/>
                        <Path Name="PART_Check"
                              Data="M3,8 L6,11 L13,4"
                              Stroke="#5DC2AF"
                              StrokeThickness="1.5"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              IsVisible="False"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox.circular:checked /template/ Ellipse#PART_Ellipse">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="#D9D9D9"/>
        </Style>
        <Style Selector="CheckBox.circular:checked /template/ Path#PART_Check">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
    </Application.Styles>

</Application>