<Page x:Class="ToDo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ToDo"
      xmlns:converters="using:ToDo.Converters"
      Background="#1C1C1C">

  <Page.Resources>
    <converters:BoolToCheckboxBackgroundConverter x:Key="CheckboxBgConverter"/>
    <converters:BoolToCheckboxBorderBrushConverter x:Key="CheckboxBorderConverter"/>
    <converters:BoolToTextDecorationsConverter x:Key="TextDecorationsConverter"/>
    <converters:BoolToForegroundConverter x:Key="ForegroundConverter"/>
  </Page.Resources>

  <Grid Padding="24,10,24,10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock Grid.Row="0"
               Text="ToDo"
               Foreground="#FFFFFF"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,14"/>

    <!-- Input -->
    <TextBox Grid.Row="1"
             x:Name="TaskInput"
             PlaceholderText="Add Task"
             Background="#303030"
             Foreground="#FFFFFF"
             PlaceholderForeground="#9B9B9B"
             Height="35"
             CornerRadius="4"
             BorderBrush="Transparent"
             BorderThickness="1"
             Padding="16,4,16,4"
             Margin="0,0,0,14"
             KeyDown="TaskInput_KeyDown"
             GotFocus="TaskInput_GotFocus"
             LostFocus="TaskInput_LostFocus"/>

    <!-- Tabs -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,3">
      <Border Padding="8,0" Height="28" Background="Transparent" Tapped="AllTab_Tapped">
        <TextBlock x:Name="AllTabText"
                   Text="All"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#D2D2D2"
                   VerticalAlignment="Center"/>
      </Border>
      <Border Padding="8,0" Height="28" Background="Transparent" Tapped="ActiveTab_Tapped">
        <TextBlock x:Name="ActiveTabText"
                   Text="Active"
                   FontSize="14"
                   FontWeight="Normal"
                   Foreground="#D2D2D2"
                   VerticalAlignment="Center"/>
      </Border>
      <Border Padding="8,0" Height="28" Background="Transparent" Tapped="CompletedTab_Tapped">
        <TextBlock x:Name="CompletedTabText"
                   Text="Completed"
                   FontSize="14"
                   FontWeight="Normal"
                   Foreground="#D2D2D2"
                   VerticalAlignment="Center"/>
      </Border>
    </StackPanel>

    <!-- Todo List -->
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding FilteredTodos}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#2A2A2A"
                    Height="35"
                    CornerRadius="4"
                    Padding="10"
                    Margin="0,0,0,5">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Circular checkbox -->
                <Border Width="16"
                        Height="16"
                        CornerRadius="8"
                        BorderThickness="2"
                        Margin="0,0,18,0"
                        Background="{Binding IsCompleted, Converter={StaticResource CheckboxBgConverter}}"
                        BorderBrush="{Binding IsCompleted, Converter={StaticResource CheckboxBorderConverter}}"
                        Tapped="Checkbox_Tapped"/>
                <!-- Task text -->
                <TextBlock Text="{Binding Task}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Foreground="{Binding IsCompleted, Converter={StaticResource ForegroundConverter}}"
                           TextDecorations="{Binding IsCompleted, Converter={StaticResource TextDecorationsConverter}}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Page>