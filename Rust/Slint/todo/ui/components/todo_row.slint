import { TodoItem } from "../types.slint";

export component TodoRow {
    in property <TodoItem> item;
    callback toggle();

    height: 35px;

    Rectangle {
        background: #2A2A2A;
        border-radius: 4px;

        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            spacing: 8px;
            alignment: start;

            // Wrapper fills layout height so inner checkbox can be centered via y
            Rectangle {
                width: 16px;

                Rectangle {
                    width: 16px;
                    height: 16px;
                    y: (parent.height - self.height) / 2;
                    border-radius: 8px;
                    border-width: 1.5px;
                    border-color: #D9D9D9;
                    background: transparent;

                    if item.is-completed: Path {
                        width: 10px;
                        height: 8px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        stroke: #5DC2AF;
                        stroke-width: 1.5px;
                        commands: "M 1 4 L 4 7 L 9 1";
                    }
                }
            }

            // Task text with strikethrough overlay
            Rectangle {
                horizontal-stretch: 1;

                task-text := Text {
                    width: parent.width;
                    height: parent.height;
                    text: item.task;
                    color: item.is-completed ? #9B9B9B : #D2D2D2;
                    font-size: 14px;
                    vertical-alignment: center;
                }

                if item.is-completed: Rectangle {
                    y: (parent.height - self.height) / 2;
                    width: task-text.preferred-width;
                    height: 1px;
                    background: #9B9B9B;
                }
            }
        }

        TouchArea {
            clicked => { root.toggle(); }
        }
    }
}